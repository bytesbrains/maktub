# Dependencies
node_modules/
yarn.lock
# NOTE: package-lock.json is intentionally committed. Lockfiles make CI
# reproducible (`npm ci` requires one). Keeping it gitignored was a past
# mistake that broke CI — see PR #11.

# Hardhat
artifacts/
cache/
dist/

# Foundry (runs alongside Hardhat for invariant/fuzz tests). The lib/ submodule
# (forge-std) and foundry.lock are committed for reproducibility; only the build
# output is ignored.
out/
cache_forge/

# Environment variables
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Testing & Coverage
coverage/
coverage.json
.nyc_output/

# Static-analysis reports (generated per run; the committed baselines are
# slither.db.json + scripts/aderyn-baseline.json, NOT these)
aderyn-report.md
aderyn-report.json

# Build artifacts
build/
dist/

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# OS files
.DS_Store
Thumbs.db

# Temporary files
.tmp/
temp/

# Internal HQ — NEVER publish
internal/
.claude/
legacy/

# Ignition deployment state (local)
ignition/deployments/

# Local ECIES private keys used by test scripts — NEVER commit.
.maktub-keys/

# Python
__pycache__/
*.pyc

# Local mobile e2e devnet artifacts (generated, never a real deployment)
mobile/integration_test/cluster/addresses.local.json
mobile/integration_test/cluster/_state/
