# Base L2 (Production)
BASE_RPC_URL=https://mainnet.base.org

# Base Sepolia (Testnet)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# Deployer wallet private key (NEVER commit the real .env file)
PRIVATE_KEY=

# Test wallet private keys — used by scripts/two-wallet-test.js and
# scripts/register-wallet-c.js. TESTNET ONLY — never use real funds here.
WALLET_A_PRIVATE_KEY=
WALLET_B_PRIVATE_KEY=
WALLET_C_PRIVATE_KEY=

# Gas reporting
REPORT_GAS=false
