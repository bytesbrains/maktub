# ─── Maktub Executor Configuration ───────────────────────────────────────

# Private key of the executor wallet (NO 0x prefix also accepted).
# This wallet will stake MKTB, call execute(), and receive rewards.
# KEEP THIS SECRET. Never commit .env to git.
PRIVATE_KEY=0xyourprivatekeyhere

# RPC endpoint for the target network.
# Base Sepolia (testnet): https://sepolia.base.org
# Base Mainnet:           https://mainnet.base.org
# For production, use a paid provider (Alchemy, Infura, QuickNode).
RPC_URL=https://sepolia.base.org

# Network selector. Must match the RPC_URL.
# Valid values: baseSepolia | base
NETWORK=baseSepolia

# ─── Optional Tuning ─────────────────────────────────────────────────────

# How often (seconds) to scan for expired heartbeats. Default: 60.
POLL_INTERVAL_SECONDS=60

# Block to start scanning from when indexing existing heartbeats.
# Leave 0 to start from the contract deployment (recommended).
START_BLOCK=0

# Automatically stake the minimum MKTB if not yet an active executor.
# Default: true. Set to false if you want to manage staking manually.
AUTO_STAKE=true

# Automatically re-stake earned MKTB rewards to compound your stake.
# Default: false.
AUTO_RESTAKE=false
